{
  "name": "ctx-link",
  "version": "0.1.0",
  "private": true,
  "description": "Connect Claude Code sessions across projects via shared context bundles",
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "bun run --filter '*' build",
    "dev:mcp": "bun --watch packages/mcp-server/src/index.ts",
    "cli": "bun packages/cli/src/index.ts",
    "typecheck": "bun run --filter '*' typecheck"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.5.0"
  }
}
