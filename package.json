{
  "name": "ctx-link",
  "version": "0.1.1",
  "description": "Connect Claude Code sessions across projects via shared context bundles",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AHK-tech/ctx-link"
  },
  "keywords": [
    "claude-code",
    "mcp",
    "context",
    "ai",
    "claude",
    "model-context-protocol"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "bin": {
    "ctx-link": "dist/mcp.js",
    "ctxl": "dist/cli.js"
  },
  "files": [
    "dist/"
  ],
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:mcp": "bun --watch packages/mcp-server/src/index.ts",
    "dev:ui": "bun run --cwd packages/ui dev",
    "dev:ui-api": "bun packages/ui/server.ts",
    "build": "bun scripts/build.ts",
    "build:ui": "bun run --cwd packages/ui build",
    "serve:ui": "bun packages/ui/server.ts",
    "cli": "bun packages/cli/src/index.ts",
    "typecheck": "bun run --filter '*' typecheck",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@supabase/supabase-js": "^2.45.0",
    "argon2": "^0.41.0",
    "commander": "^12.1.0",
    "@inquirer/prompts": "^8.4.2",
    "nanoid": "^5.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.5.0",
    "@base-ui/react": "^1.4.1",
    "@fontsource-variable/geist": "^5.2.8",
    "@tailwindcss/vite": "^4.0.0",
    "@tanstack/react-query": "^5.0.0",
    "@types/dagre": "^0.7.52",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "@xyflow/react": "^12.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dagre": "^0.8.5",
    "date-fns": "^4.0.0",
    "lucide-react": "^1.8.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shadcn": "^4.4.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.0.0",
    "tw-animate-css": "^1.4.0",
    "vite": "^6.0.0",
    "zustand": "^5.0.12"
  }
}
